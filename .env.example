# MatSci-Agent Configuration
# Copy this file to .env and fill in your values

# ── LLM Provider ──
# Supported: anthropic, openai, ollama, deepseek, google-genai, openrouter, nvidia
# Default: auto-detect (checks env vars in order: ANTHROPIC_API_KEY, OPENAI_API_KEY, etc.)
MATSCI_PROVIDER=anthropic

# Model name (provider-specific)
# Anthropic: claude-sonnet-4-6, claude-opus-4
# OpenAI: gpt-5.4, gpt-4o, o1
# Ollama: qwen2.5:14b, llama3.1, mistral, etc.
# DeepSeek: deepseek-chat, deepseek-reasoner
# Google: gemini-2.5-pro, gemini-2.0-flash
MATSCI_MODEL=claude-sonnet-4-6

# Generic API key (highest priority — overrides provider-specific keys)
# MATSCI_API_KEY=sk-ant-...

# Provider-specific API keys (used if MATSCI_API_KEY not set)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
# GOOGLE_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# NVIDIA_API_KEY=nvapi-...

# Custom base URL (for OpenAI-compatible APIs or proxies)
# MATSCI_BASE_URL=https://custom.api.endpoint.com/v1

# Ollama base URL (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# ── Computational Tools ──
# LAMMPS executable path (auto-detected if not set)
# LAMMPS_EXECUTABLE=C:\Program Files\LAMMPS\bin\lmp.exe

# VASP executable path (auto-detected if not set)
# VASP_EXECUTABLE=C:\Program Files\VASP\bin\vasp_std.exe

# ── HPC Settings ──
# HPC_SCHEDULER=local
# HPC_HOST=hpc.university.edu
# HPC_USERNAME=your_username

# ── Agent Behavior ──
# Auto-approve all tool calls (use with caution!)
# MATSCI_AUTO_APPROVE=false

# Enable multi-branch exploration
# MATSCI_ENABLE_EXPLORATION=true

# Max parallel branches
# MATSCI_MAX_BRANCHES=5
