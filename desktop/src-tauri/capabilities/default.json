{
  "identifier": "default",
  "description": "Default capabilities for the MatSci-Agent desktop app",
  "windows": ["main", "pet"],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:window:allow-set-focus",
    "core:window:allow-get",
    "shell:default",
    "notification:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "sidecars/matsci",
          "sidecar": true,
          "args": true
        },
        {
          "name": "sidecars/matsci-sidecar",
          "sidecar": true,
          "args": true
        },
        {
          "name": "python",
          "cmd": "python",
          "args": true,
          "sidecar": false
        }
      ]
    },
    {
      "identifier": "shell:allow-kill",
      "allow": [
        {
          "name": "sidecars/matsci",
          "sidecar": true
        },
        {
          "name": "sidecars/matsci-sidecar",
          "sidecar": true
        },
        {
          "name": "python",
          "cmd": "python",
          "sidecar": false
        }
      ]
    }
  ]
}
