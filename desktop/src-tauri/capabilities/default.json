{
  "identifier": "default",
  "description": "Default capabilities for the MatSci-Agent desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "notification:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "sidecars/matsci",
          "sidecar": true,
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-kill",
      "allow": [
        {
          "name": "sidecars/matsci",
          "sidecar": true
        }
      ]
    }
  ]
}
