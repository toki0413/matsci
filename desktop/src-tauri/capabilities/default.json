{
  "identifier": "default",
  "description": "Default capabilities for the Huginn desktop app",
  "windows": ["main", "pet"],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:window:allow-set-focus",
    "core:window:allow-start-dragging",
    "core:webview:allow-get-all-webviews",
    "core:webview:allow-create-webview-window",
    "shell:default",
    "notification:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "sidecars/huginn",
          "sidecar": true,
          "args": ["serve", "--port", { "regex": "^[0-9]+$" }]
        },
        {
          "name": "sidecars/huginn-sidecar",
          "sidecar": true,
          "args": []
        },
        {
          "name": "python",
          "cmd": "python",
          "args": ["-m", "huginn.server", "--port", { "regex": "^[0-9]+$" }],
          "sidecar": false
        }
      ]
    },
    {
      "identifier": "shell:allow-kill",
      "allow": [
        {
          "name": "sidecars/huginn",
          "sidecar": true
        },
        {
          "name": "sidecars/huginn-sidecar",
          "sidecar": true
        },
        {
          "name": "python",
          "cmd": "python",
          "sidecar": false
        }
      ]
    }
  ]
}
